{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm build && rm -f dist/space-explorer/browser/index.csr.html",
  "outputDirectory": "dist/space-explorer/browser",
  "rewrites": [
    { "source": "/", "destination": "/api/ssr" },
    { "source": "/(.*)", "destination": "/api/ssr" }
  ],
  "functions": {
    "api/ssr.mjs": {
      "includeFiles": "dist/space-explorer/**"
    }
  }
}
