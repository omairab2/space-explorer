{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/space-explorer/browser",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/ssr" }],
  "functions": {
    "api/ssr.mjs": {
      "includeFiles": "dist/space-explorer/**"
    }
  }
}
